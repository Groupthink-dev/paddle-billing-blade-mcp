# Required: Paddle API key (Developer Tools > Authentication)
PADDLE_API_KEY=pdl_sdbx_your_sandbox_key_here

# Required: API environment — must be "sandbox" or "production"
PADDLE_ENVIRONMENT=sandbox

# Optional: Enable write operations (create, update, cancel, etc.)
PADDLE_WRITE_ENABLED=false

# Optional: Webhook signing secret for HMAC verification
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_your_secret_here

# Optional: MCP transport (stdio or http)
# PADDLE_MCP_TRANSPORT=stdio

# Optional: HTTP transport settings
# PADDLE_MCP_HOST=127.0.0.1
# PADDLE_MCP_PORT=8769

# Optional: Bearer token for HTTP transport auth
# PADDLE_MCP_API_TOKEN=your_mcp_bearer_token
